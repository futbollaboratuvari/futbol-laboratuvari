  "redirects": [
    {
      "source": "/:path*",
      "has": [{ "type": "host", "value": "futbollaboratuuvari.org" }],
      "destination": "https://www.futbollaboratuuvari.org/:path*",
      "permanent": true
    },
    {
      "source": "/:path*",
