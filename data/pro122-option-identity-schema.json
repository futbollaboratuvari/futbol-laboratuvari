  "safe_mode": true,
  "match_id_rule": {
    "format": "date|league|home|away|time",
    "example": "2026 06 26|belarus premier lig|arsenal|gomel|20 00",
    "required_fields": [
      "date",
      "league",
      "home",
      "away",
      "time"
    ]
  },
  "option_id_rule": {
    "format": "match_id|option_type|selection",
    "example": "2026 06 26|belarus premier lig|arsenal|gomel|20 00|ms|1",
