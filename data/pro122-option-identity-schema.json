      "match_id",
      "option_type",
      "selection"
    ]
  },
  "option_groups": [
    {
      "option_type": "MS",
      "selections": ["1", "X", "2"],
      "score_requirement": "full_time_score"
    },
    {
      "option_type": "KG",
      "selections": ["Var", "Yok"],
      "score_requirement": "full_time_score"
    },
    {
      "option_type": "2.5",
      "selections": ["Ust", "Alt"],
      "score_requirement": "full_time_score"
    },
    {
      "option_type": "IY_MS",
      "selections": ["1 / 1", "1 / X", "1 / 2", "X / 1", "X / X", "X / 2", "2 / 1", "2 / X", "2 / 2"],
      "score_requirement": "half_time_score + full_time_score"
    },
    {
      "option_type": "IY_KG_2Y_KG",
      "selections": ["Evet / Evet", "Evet / Hayir", "Hayir / Evet", "Hayir / Hayir"],
      "score_requirement": "half_time_score + full_time_score"
    }
  ],
  "write_rule": "Eski id alanlari silinmez. match_id ve option_id yeni bag alanlari olarak eklenir.",
